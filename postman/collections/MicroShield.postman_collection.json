{
  "info": {
    "_postman_id": "9a0ea879-ec10-4dc7-ae36-microshield2026",
    "name": "MicroShield Demo",
    "description": "Requests for API Gateway 8085, JWT, BOLA, RabbitMQ and rate limiting demos.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "gateway",
      "value": "http://localhost:8085"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "userAOrderId",
      "value": "1"
    },
    {
      "key": "userBOrderId",
      "value": "2"
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login userA",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('token', body.token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"username\": \"userA\", \"password\": \"123456\"}"
            },
            "url": {
              "raw": "{{gateway}}/api/auth/login",
              "host": [
                "{{gateway}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            }
          }
        },
        {
          "name": "Login admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('token', body.token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"username\": \"admin\", \"password\": \"admin123\"}"
            },
            "url": {
              "raw": "{{gateway}}/api/auth/login",
              "host": [
                "{{gateway}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Orders and BOLA",
      "item": [
        {
          "name": "List current user's orders",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{gateway}}/api/orders",
              "host": [
                "{{gateway}}"
              ],
              "path": [
                "api",
                "orders"
              ]
            }
          }
        },
        {
          "name": "Read userA order",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{gateway}}/api/orders/{{userAOrderId}}",
              "host": [
                "{{gateway}}"
              ],
              "path": [
                "api",
                "orders",
                "{{userAOrderId}}"
              ]
            }
          }
        },
        {
          "name": "BOLA - read userB order as userA",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{gateway}}/api/orders/{{userBOrderId}}",
              "host": [
                "{{gateway}}"
              ],
              "path": [
                "api",
                "orders",
                "{{userBOrderId}}"
              ]
            }
          }
        },
        {
          "name": "Create order and publish RabbitMQ event",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"productName\": \"Keyboard\", \"quantity\": 1, \"totalPrice\": 50}"
            },
            "url": {
              "raw": "{{gateway}}/api/orders",
              "host": [
                "{{gateway}}"
              ],
              "path": [
                "api",
                "orders"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Inventory",
      "item": [
        {
          "name": "List inventory",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{gateway}}/api/inventory",
              "host": [
                "{{gateway}}"
              ],
              "path": [
                "api",
                "inventory"
              ]
            }
          }
        },
        {
          "name": "Get Keyboard stock",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{gateway}}/api/inventory/Keyboard",
              "host": [
                "{{gateway}}"
              ],
              "path": [
                "api",
                "inventory",
                "Keyboard"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Admin dashboard",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{gateway}}/api/admin/dashboard",
              "host": [
                "{{gateway}}"
              ],
              "path": [
                "api",
                "admin",
                "dashboard"
              ]
            }
          }
        }
      ]
    }
  ]
}